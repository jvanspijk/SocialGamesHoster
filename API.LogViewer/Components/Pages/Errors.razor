@page "/errors"
@inject ILogService LogService
@inject IJSRuntime JSRuntime

<PageTitle>Errors</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1">Errors</h2>
            <p class="text-muted small mb-0">Inspect recent exceptions with trace context.</p>
        </div>
        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadErrorsAsync" disabled="@isLoading">
            <i class="bi bi-arrow-clockwise me-1"></i>
            Refresh
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex flex-wrap gap-2 align-items-center">
            <input class="form-control" style="max-width: 360px;"
                   placeholder="Search message, trace, endpoint, method..."
                   @bind="searchText"
                   @bind:event="oninput" />

            <select class="form-select" style="max-width: 260px;" @bind="selectedExceptionType">
                <option value="">All exceptions</option>
                @foreach (var exceptionType in ExceptionTypes)
                {
                    <option value="@exceptionType">@exceptionType</option>
                }
            </select>

            <span class="badge bg-light text-dark border">@FilteredErrors.Count errors</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive" style="max-height: 80vh;">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light sticky-top">
                    <tr class="text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                        <th class="ps-4" style="width: 180px;">Timestamp</th>
                        <th style="width: 110px;">Method</th>
                        <th style="width: 220px;">Exception</th>
                        <th>Message</th>
                        <th style="width: 280px;">Endpoint</th>
                        <th class="pe-4" style="width: 190px;">Trace ID</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Loading errors...</td>
                        </tr>
                    }
                    else if (FilteredErrors.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No errors found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var error in FilteredErrors)
                        {
                            var isExpanded = expandedErrorId == error.Id;
                            var stackTraceCopyId = $"stacktrace-{error.Id}";

                            <tr class="@(isExpanded ? "table-active" : string.Empty)">
                                <td class="ps-4 text-muted small">@error.Timestamp</td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(error.ErrorMethod))
                                    {
                                        <span class="text-muted small">N/A</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark-subtle text-dark border">@error.ErrorMethod</span>
                                    }
                                </td>
                                <td><span class="badge bg-danger-subtle text-danger border">@error.ExceptionType</span></td>
                                <td class="text-break">@error.Message</td>
                                <td class="small font-monospace text-muted">@error.Endpoint</td>
                                <td class="pe-4 small font-monospace">
                                    <button type="button"
                                            class="btn btn-link p-0 text-decoration-none trace-link"
                                            @onclick="() => ToggleExpanded(error.Id)">
                                        @error.TraceId
                                    </button>
                                </td>
                            </tr>

                            @if (isExpanded)
                            {
                                <tr class="bg-light">
                                    <td colspan="6" class="p-0 border-0">
                                        <div class="p-3 mx-3 my-2 border-start border-4 border-danger rounded bg-white shadow-sm">
                                            <div class="d-flex flex-wrap gap-2 mb-3">
                                                @if (!string.IsNullOrWhiteSpace(error.ExceptionSource))
                                                {
                                                    <span class="badge bg-light text-dark border">Source: @error.ExceptionSource</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(error.TargetSite))
                                                {
                                                    <span class="badge bg-light text-dark border">Target: @error.TargetSite</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(error.StackTraceHash))
                                                {
                                                    <span class="badge bg-secondary-subtle text-secondary border font-monospace">Hash: @error.StackTraceHash[..Math.Min(12, error.StackTraceHash.Length)]</span>
                                                }
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <h6 class="mb-0 text-uppercase text-muted small fw-bold">Stack Trace</h6>
                                                <button class="btn btn-link btn-sm p-0 text-decoration-none"
                                                        @onclick="() => CopyToClipboard(error.StackTrace, stackTraceCopyId)">
                                                    @if (lastCopiedId == stackTraceCopyId)
                                                    {
                                                        <span class="text-success"><i class="bi bi-check-lg me-1"></i>Copied</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-primary"><i class="bi bi-clipboard me-1"></i>Copy</span>
                                                    }
                                                </button>
                                            </div>
                                            <pre class="m-0"><code>@(string.IsNullOrWhiteSpace(error.StackTrace) ? "No stack trace available." : error.StackTrace)</code></pre>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<ErrorEntry> errors = [];
    private bool isLoading;
    private string? selectedExceptionType;
    private string searchText = string.Empty;
    private long? expandedErrorId;
    private string? lastCopiedId;

    private List<ErrorEntry> FilteredErrors =>
        errors
            .Where(error => string.IsNullOrWhiteSpace(selectedExceptionType) || error.ExceptionType == selectedExceptionType)
            .Where(error => string.IsNullOrWhiteSpace(searchText)
                || error.Message.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                || error.TraceId.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                || error.Endpoint.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                || error.ErrorMethod.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                || error.ExceptionType.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private List<string> ExceptionTypes =>
        errors
            .Select(error => error.ExceptionType)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(exceptionType => exceptionType, StringComparer.OrdinalIgnoreCase)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadErrorsAsync();
    }

    private async Task LoadErrorsAsync()
    {
        isLoading = true;
        try
        {
            errors = await LogService.GetLatestErrorsAsync();
            if (expandedErrorId.HasValue && errors.All(error => error.Id != expandedErrorId.Value))
            {
                expandedErrorId = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            errors = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleExpanded(long errorId)
    {
        expandedErrorId = expandedErrorId == errorId ? null : errorId;
    }

    private async Task CopyToClipboard(string text, string uniqueId)
    {
        await JSRuntime.InvokeVoidAsync("copyToClipboard", text);
        lastCopiedId = uniqueId;

        _ = Task.Delay(1500).ContinueWith(_ =>
        {
            lastCopiedId = null;
            InvokeAsync(StateHasChanged);
        });
    }
}
