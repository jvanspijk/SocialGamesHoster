@page "/exceptions"
@using System.Globalization
@using System.Timers
@inject ILogService LogService
@inject IJSRuntime JSRuntime
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Exceptions</PageTitle>

<div class="container-fluid py-4 exceptions-page">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1">Exceptions</h2>
            <p class="text-muted small mb-0">Inspect recent exceptions with trace context.</p>
        </div>
        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadExceptionsAsync" disabled="@isLoading">
            <i class="bi bi-arrow-clockwise me-1"></i>
            Refresh
        </button>
    </div>

    <Table TItem="ExceptionEntry"
                  Items="FilteredAndSortedExceptions"
                  ColumnCount="6"
                  SearchText="@searchText"
                  SearchTextChanged="OnSearchChanged"
                  SearchPlaceholder="Search message, trace, endpoint, method..."
                  IsLoading="@isLoading"
                  LoadingText="Loading exceptions..."
                  EmptyText="No exceptions found."
                  CountLabel="exceptions">
        <ToolbarContent>
            <select class="form-select" style="max-width: 260px;" @bind="selectedExceptionType">
                <option value="">All exceptions</option>
                @foreach (var exceptionType in ExceptionTypes)
                {
                    <option value="@exceptionType">@exceptionType</option>
                }
            </select>
        </ToolbarContent>
        <HeaderTemplate>
            <tr class="text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                <th class="ps-4" style="width: 180px;">
                    <button type="button" class="sort-header" @onclick="() => SetSort(SortColumn.Timestamp)">
                        Timestamp @GetSortIndicator(SortColumn.Timestamp)
                    </button>
                </th>
                <th style="width: 110px;">
                    <button type="button" class="sort-header" @onclick="() => SetSort(SortColumn.Method)">
                        Method @GetSortIndicator(SortColumn.Method)
                    </button>
                </th>
                <th style="width: 220px;">
                    <button type="button" class="sort-header" @onclick="() => SetSort(SortColumn.Exception)">
                        Exception @GetSortIndicator(SortColumn.Exception)
                    </button>
                </th>
                <th>
                    <button type="button" class="sort-header" @onclick="() => SetSort(SortColumn.Message)">
                        Message @GetSortIndicator(SortColumn.Message)
                    </button>
                </th>
                <th style="width: 280px;">
                    <button type="button" class="sort-header" @onclick="() => SetSort(SortColumn.Endpoint)">
                        Endpoint @GetSortIndicator(SortColumn.Endpoint)
                    </button>
                </th>
                <th class="pe-4" style="width: 190px;">
                    <button type="button" class="sort-header" @onclick="() => SetSort(SortColumn.TraceId)">
                        Trace ID @GetSortIndicator(SortColumn.TraceId)
                    </button>
                </th>
            </tr>
        </HeaderTemplate>
        <RowTemplate Context="exceptionEntry">
            @{
                var isExpanded = expandedExceptionId == exceptionEntry.Id;
                var stackTraceCopyId = $"stacktrace-{exceptionEntry.Id}";
            }

            <tr class="@(isExpanded ? "table-active app-row-expanded" : string.Empty)">
                <td class="ps-4 text-muted small">@exceptionEntry.Timestamp</td>
                <td>
                    @if (string.IsNullOrWhiteSpace(exceptionEntry.ErrorMethod))
                    {
                        <span class="text-muted small">N/A</span>
                    }
                    else
                    {
                        <span class="badge app-badge-neutral border">@exceptionEntry.ErrorMethod</span>
                    }
                </td>
                <td><span class="badge app-badge-danger border">@exceptionEntry.ExceptionType</span></td>
                <td class="text-break">@exceptionEntry.Message</td>
                <td class="small font-monospace text-muted">@exceptionEntry.Endpoint</td>
                <td class="pe-4 small font-monospace">
                    <button type="button"
                            class="btn btn-link p-0 text-decoration-none trace-link text-start w-100"
                            @onclick="() => ToggleExpandedAsync(exceptionEntry)"
                            aria-expanded="@isExpanded">
                        @exceptionEntry.TraceId
                    </button>
                </td>
            </tr>

            @if (isExpanded)
            {
                <tr class="app-expanded-row">
                    <td colspan="6" class="p-0 border-0">
                        <div class="exception-details-panel p-3 mx-3 my-2 border-start border-4 rounded shadow-sm">
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @if (!string.IsNullOrWhiteSpace(exceptionEntry.ExceptionSource))
                                {
                                    <span class="badge app-badge-neutral border">Source: @exceptionEntry.ExceptionSource</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(exceptionEntry.TargetSite))
                                {
                                    <span class="badge app-badge-neutral border">Target: @exceptionEntry.TargetSite</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(exceptionEntry.StackTraceHash))
                                {
                                    <span class="badge app-badge-muted border font-monospace">Hash: @exceptionEntry.StackTraceHash[..Math.Min(12, exceptionEntry.StackTraceHash.Length)]</span>
                                }
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0 text-uppercase text-muted small fw-bold">Stack Trace</h6>
                                <button class="btn btn-link btn-sm p-0 text-decoration-none"
                                        @onclick="() => CopyToClipboard(exceptionEntry.StackTrace, stackTraceCopyId)">
                                    @if (lastCopiedId == stackTraceCopyId)
                                    {
                                        <span class="text-success"><i class="bi bi-check-lg me-1"></i>Copied</span>
                                    }
                                    else
                                    {
                                        <span class="app-link"><i class="bi bi-clipboard me-1"></i>Copy</span>
                                    }
                                </button>
                            </div>
                            <pre class="m-0"><code>@(string.IsNullOrWhiteSpace(exceptionEntry.StackTrace) ? "No stack trace available." : exceptionEntry.StackTrace)</code></pre>
                        </div>

                        @if (isLoadingTraceContext)
                        {
                            <div class="px-4 pb-3 text-muted small">Loading request context...</div>
                        }
                        else
                        {
                            <TraceDetailsPanel RequestBody="@expandedRequest?.Body" Details="@expandedTraceDetails" />
                        }
                    </td>
                </tr>
            }
        </RowTemplate>
    </Table>
</div>

@code {
    private List<ExceptionEntry> exceptions = [];
    private bool isLoading;
    private string? selectedExceptionType;
    private string searchText = string.Empty;
    private long? expandedExceptionId;
    private string? lastCopiedId;
    private Timer? timer;
    private SortColumn currentSortColumn = SortColumn.Timestamp;
    private bool isSortAscending;
    private RequestEntry? expandedRequest;
    private List<TraceDetail> expandedTraceDetails = [];
    private bool isLoadingTraceContext;

    private IReadOnlyList<ExceptionEntry> FilteredAndSortedExceptions => SortExceptions(FilteredExceptions).ToList();

    private IEnumerable<ExceptionEntry> FilteredExceptions =>
        exceptions
            .Where(exceptionEntry => string.IsNullOrWhiteSpace(selectedExceptionType) || exceptionEntry.ExceptionType == selectedExceptionType)
            .Where(MatchesSearch);

    private List<string> ExceptionTypes =>
        exceptions
            .Select(exceptionEntry => exceptionEntry.ExceptionType)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(exceptionType => exceptionType, StringComparer.OrdinalIgnoreCase)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadExceptionsAsync();

        timer = new Timer(2500);
        timer.Elapsed += async (_, _) =>
        {
            await InvokeAsync(async () =>
            {
                await LoadExceptionsAsync();
                StateHasChanged();
            });
        };

        timer.Start();
    }

    private async Task LoadExceptionsAsync()
    {
        isLoading = true;
        try
        {
            exceptions = await LogService.GetLatestExceptionsAsync();
            if (expandedExceptionId.HasValue && exceptions.All(exceptionEntry => exceptionEntry.Id != expandedExceptionId.Value))
            {
                expandedExceptionId = null;
                expandedRequest = null;
                expandedTraceDetails = [];
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            exceptions = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleExpandedAsync(ExceptionEntry exceptionEntry)
    {
        if (expandedExceptionId == exceptionEntry.Id)
        {
            expandedExceptionId = null;
            expandedRequest = null;
            expandedTraceDetails = [];
            return;
        }

        expandedExceptionId = exceptionEntry.Id;
        expandedRequest = null;
        expandedTraceDetails = [];
        isLoadingTraceContext = true;
        StateHasChanged();

        try
        {
            var requestTask = LogService.GetRequestByTraceIdAsync(exceptionEntry.TraceId);
            var detailsTask = LogService.GetTraceDetailsAsync(exceptionEntry.TraceId);

            await Task.WhenAll(requestTask, detailsTask);

            expandedRequest = await requestTask;
            expandedTraceDetails = await detailsTask;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            expandedRequest = null;
            expandedTraceDetails = [];
        }
        finally
        {
            isLoadingTraceContext = false;
        }
    }

    private async Task CopyToClipboard(string text, string uniqueId)
    {
        await JSRuntime.InvokeVoidAsync("copyToClipboard", text);
        lastCopiedId = uniqueId;

        _ = Task.Delay(1500).ContinueWith(_ =>
        {
            lastCopiedId = null;
            InvokeAsync(StateHasChanged);
        });
    }

    public void Dispose() => timer?.Dispose();

    private Task OnSearchChanged(string value)
    {
        searchText = value;
        return Task.CompletedTask;
    }

    private bool MatchesSearch(ExceptionEntry exceptionEntry)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
        }

        return exceptionEntry.Message.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || exceptionEntry.TraceId.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || exceptionEntry.Endpoint.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || exceptionEntry.ErrorMethod.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || exceptionEntry.ExceptionType.Contains(searchText, StringComparison.OrdinalIgnoreCase);
    }

    private void SetSort(SortColumn column)
    {
        if (currentSortColumn == column)
        {
            isSortAscending = !isSortAscending;
            return;
        }

        currentSortColumn = column;
        isSortAscending = column != SortColumn.Timestamp;
    }

    private string GetSortIndicator(SortColumn column)
    {
        if (currentSortColumn != column)
        {
            return "↕";
        }

        return isSortAscending ? "▲" : "▼";
    }

    private static DateTimeOffset ParseTimestamp(string timestamp)
    {
        if (DateTimeOffset.TryParse(timestamp, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var parsed))
        {
            return parsed;
        }

        return DateTimeOffset.MinValue;
    }

    private IEnumerable<ExceptionEntry> SortExceptions(IEnumerable<ExceptionEntry> source) => currentSortColumn switch
    {
        SortColumn.Timestamp => isSortAscending
            ? source.OrderBy(exceptionEntry => ParseTimestamp(exceptionEntry.Timestamp)).ThenBy(exceptionEntry => exceptionEntry.Timestamp, StringComparer.OrdinalIgnoreCase)
            : source.OrderByDescending(exceptionEntry => ParseTimestamp(exceptionEntry.Timestamp)).ThenByDescending(exceptionEntry => exceptionEntry.Timestamp, StringComparer.OrdinalIgnoreCase),
        SortColumn.Method => isSortAscending
            ? source.OrderBy(exceptionEntry => exceptionEntry.ErrorMethod, StringComparer.OrdinalIgnoreCase)
            : source.OrderByDescending(exceptionEntry => exceptionEntry.ErrorMethod, StringComparer.OrdinalIgnoreCase),
        SortColumn.Exception => isSortAscending
            ? source.OrderBy(exceptionEntry => exceptionEntry.ExceptionType, StringComparer.OrdinalIgnoreCase)
            : source.OrderByDescending(exceptionEntry => exceptionEntry.ExceptionType, StringComparer.OrdinalIgnoreCase),
        SortColumn.Message => isSortAscending
            ? source.OrderBy(exceptionEntry => exceptionEntry.Message, StringComparer.OrdinalIgnoreCase)
            : source.OrderByDescending(exceptionEntry => exceptionEntry.Message, StringComparer.OrdinalIgnoreCase),
        SortColumn.Endpoint => isSortAscending
            ? source.OrderBy(exceptionEntry => exceptionEntry.Endpoint, StringComparer.OrdinalIgnoreCase)
            : source.OrderByDescending(exceptionEntry => exceptionEntry.Endpoint, StringComparer.OrdinalIgnoreCase),
        SortColumn.TraceId => isSortAscending
            ? source.OrderBy(exceptionEntry => exceptionEntry.TraceId, StringComparer.OrdinalIgnoreCase)
            : source.OrderByDescending(exceptionEntry => exceptionEntry.TraceId, StringComparer.OrdinalIgnoreCase),
        _ => source
    };

    private enum SortColumn
    {
        Timestamp,
        Method,
        Exception,
        Message,
        Endpoint,
        TraceId
    }
}
