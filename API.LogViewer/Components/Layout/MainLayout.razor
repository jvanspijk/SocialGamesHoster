@inherits LayoutComponentBase

<div class="app-shell d-flex">
    <div class="sidebar app-sidebar p-4 d-none d-md-block shadow flex-shrink-0">
        <h5 class="fw-bold mb-4">API Debug <span class="app-accent-text">Logs</span></h5>
        <nav class="nav flex-column gap-2">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <i class="bi bi-list-ul me-2"></i> Requests
            </NavLink>
            <NavLink class="nav-link" href="/queries">
                <i class="bi bi-database me-2"></i> Queries
            </NavLink>
            <NavLink class="nav-link" href="/errors">
                <i class="bi bi-exclamation-octagon me-2"></i> Errors
            </NavLink>
        </nav>
    </div>

    <div class="app-content flex-grow-1 d-flex flex-column">
        <header class="navbar app-header border-bottom px-4 py-3 shadow-sm">
            <span class="text-muted fw-medium">Overview</span>

            <button class="btn btn-sm btn-outline-secondary" type="button" data-theme-toggle>
                <i class="bi bi-moon me-1" data-theme-toggle-icon></i>
                <span data-theme-toggle-text>Dark mode</span>
            </button>
        </header>

        <main class="p-4 page-main">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
