  </ItemGroup>

  <ItemGroup>
    <Service Include="{508349b6-6b84-4df5-91f0-309beebad82d}" />
  </ItemGroup>

  <Target Name="PreBuild" BeforeTargets="PreBuildEvent">
    <Exec Command="net start &quot;postgresql-x64-18&quot; 2&gt;nul || exit 0" />
  </Target>

</Project>
