{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Vite: Debug",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "dev"],
			"serverReadyAction": {
				"pattern": "Local:   (https?://.+)",
				"uriFormat": "%s",
				"action": "openExternally"
			},
			"outputCapture": "std"
		}
	]
}
